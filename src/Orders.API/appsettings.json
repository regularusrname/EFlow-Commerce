{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "Enrich": [
        "FromLogContext"
    ],
    "WriteTo": ["Console"],
    "Properties": {
      "Application": "Order.API",
      "Environment": "Development"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=eflow_orders-dev;Username=eflow-dev_user;Password=secret"
  },
  "ExternalServices": {
    "Catalog": {
      "BaseUrl": "http://localhost:5063"
    }
  },
  "AllowedHosts": "*"
}
