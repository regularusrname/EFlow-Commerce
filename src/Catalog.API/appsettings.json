{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [{ "Name": "Console" }],
    "Properties": {
      "Application": "Catalog.API",
      "Environment": "Development"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=eflow_catalog-dev;Username=eflow-dev_user;Password=secret"
  },
  "AllowedHosts": "*"
}
